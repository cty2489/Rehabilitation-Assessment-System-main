# Standalone retrieval service settings. Copy to the deployment data directory
# as rag.env; never expose the service outside localhost.
RAG_ENABLED=0
RAG_ALLOW_DEMO=0
RAG_BACKEND=local
RAG_COLLECTION=rehab_knowledge_demo_v0_1
RAG_QDRANT_PATH=/root/autodl-tmp/rehab_project/knowledge_base/vector_store/qdrant_local
RAG_QDRANT_URL=http://127.0.0.1:6333
RAG_EMBEDDING_MODEL=/root/autodl-tmp/rag_models/BAAI/bge-m3
RAG_DEVICE=cpu
RAG_TOP_K=5
RAG_MAX_SEQUENCE_LENGTH=1024
RAG_BATCH_SIZE=8
RAG_SERVICE_HOST=127.0.0.1
RAG_SERVICE_PORT=8010
