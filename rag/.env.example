# The production backend does not read these settings yet. They configure only
# the standalone retrieval scripts in the RAG experiment.
RAG_ENABLED=0
RAG_BACKEND=local
RAG_COLLECTION=rehab_knowledge_demo_v0_1
RAG_QDRANT_PATH=/root/autodl-tmp/rehab_project/Rehabilitation-Assessment-System-main/knowledge_base/vector_store/qdrant_local
RAG_QDRANT_URL=http://127.0.0.1:6333
RAG_EMBEDDING_MODEL=/root/autodl-tmp/rag_models/BAAI/bge-m3
RAG_DEVICE=cpu
RAG_TOP_K=5
RAG_MAX_SEQUENCE_LENGTH=1024
RAG_BATCH_SIZE=8
