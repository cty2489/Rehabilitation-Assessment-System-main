{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rehab.example/schemas/device-patient-v1.schema.json",
  "title": "Device patient registration v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "patient_id",
    "name",
    "sex",
    "age",
    "diagnosis",
    "paralysis_side"
  ],
  "properties": {
    "schema_version": {
      "const": "rehab.patient.v1"
    },
    "patient_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9]{2,31}_[0-9]{4,8}$",
      "examples": ["DEV001_0001"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "sex": {
      "enum": ["男", "女"]
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120
    },
    "diagnosis": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "paralysis_side": {
      "enum": ["左", "右"]
    },
    "disease_days": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "hand_brunnstrom_stage": {
      "type": ["string", "null"],
      "enum": ["I", "II", "III", "IV", "V", "VI", null],
      "description": "登记时的Brunnstrom手功能分期，云端映射为初始hand_function"
    }
  }
}
