# Copy to backend/.env and adjust if needed.
# Report generation provider.
# Leave LLM_PROVIDER empty to preserve the legacy auto mode:
#   LLM_REMOTE_URL set  -> custom remote llm_server.py service
#   LLM_REMOTE_URL empty -> local Yi-1.5-6B-Chat load
#
# Recommended no-GPU mode for this workstation:
#   LLM_PROVIDER=deepseek
#   DEEPSEEK_API_KEY=sk-...
LLM_PROVIDER=

# ── DeepSeek API mode (OpenAI-compatible /chat/completions) ────────────────
# Set LLM_PROVIDER=deepseek to use these. The backend still builds and validates
# the structured clinical JSON; DeepSeek only generates the clinical text JSON.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Use deepseek-v4-flash for speed/cost, or deepseek-v4-pro for stronger reasoning.
# deepseek-chat and deepseek-reasoner are deprecated after 2026-07-24.
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=180
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0
DEEPSEEK_DISABLE_THINKING=1

# Yi mode uses the UN-FINE-TUNED Yi-1.5-6B-Chat base model (the QLoRA adapter is
# no longer attached by default — see LLM_USE_ADAPTER below).

# ── Remote mode (recommended when the backend host has no GPU, e.g. a Mac):
#    DL predictions run locally on CPU; report generation is delegated to the
#    cloud-GPU service (llm_server.py). For AutoDL/seetacloud, paste the public
#    "自定义服务" HTTPS URL here (it maps to the instance's internal port 6006).
#    Leave EMPTY to use local mode instead.
LLM_REMOTE_URL=https://uXXXXXX-xxxx-xxxxxxxx.xxxx.seetacloud.com:8443
# Remote request timeout in seconds (report generation can take tens of seconds).
LLM_REMOTE_TIMEOUT=180

# ── Local mode (GPU box only): leave LLM_REMOTE_URL empty; the backend loads
#    the model in-process using the knobs below.
# LoRA adapter directory (default: <project_root>/checkpoints_llm/yi15_6b)
LLM_ADAPTER_DIR=../checkpoints_llm/yi15_6b
# model_registry id used to resolve the base model + stop tokens
LLM_MODEL_ID=yi15_6b
# Load base in 4-bit NF4 (needs CUDA GPU + bitsandbytes). Set 0 for bf16/fp16.
LLM_LOAD_4BIT=1
# Attach the QLoRA adapter? 0 (default) = use the un-fine-tuned Yi-1.5-6B-Chat
# base model directly; 1 = base + LoRA adapter from LLM_ADAPTER_DIR. Set the same
# value on the cloud llm_server.py box.
LLM_USE_ADAPTER=0

# ── MySQL (设备端 / 任务一与任务三对接接口工作流) ──────────────────────────────
# 独立于「康复评估」页用的 SQLite。仅「任务一与任务三对接接口页面」的患者入组与
# 设备评估记录写入这里。库不存在时后端会自动创建（CREATE DATABASE + 建表）。
# 若本地未启动 MySQL，后端启动只告警、不报错，SQLite 流程照常可用。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=rehab_mysql
