# Copy this file to backend/.env and fill real values.
# Never commit backend/.env.

# ── Application login / API auth ────────────────────────────────────────────
# The browser page posts username/password to /api/auth/login.
# The backend signs a short-lived HttpOnly browser session with APP_AUTH_TOKEN.
# APP_AUTH_TOKEN is the session-signing secret. Permanent Bearer use is off by default.
APP_ADMIN_USER=admin
APP_ADMIN_PASSWORD=change-this-password
APP_AUTH_TOKEN=generate-a-long-random-token
APP_VERSION=unreleased
# The production start script fills this from git when left empty.
APP_BUILD_COMMIT=
APP_SESSION_TTL_SECONDS=28800
ALLOW_LEGACY_ADMIN_BEARER=0
# Same-origin deployment needs no CORS. Add explicit origins only for a separate UI host.
APP_CORS_ORIGINS=
APP_LOGIN_RATE_LIMIT=5
APP_LOGIN_RATE_WINDOW_SECONDS=300

# ── Device-to-cloud API auth ────────────────────────────────────────────────
# Used by /api/device/v1/* machine endpoints. Keep it different from
# APP_AUTH_TOKEN so training devices never need the browser/admin credential.
DEVICE_API_TOKEN=
# Shared legacy credentials are disabled by default. Set this to 1 only during
# a short migration window, then issue one named credential per physical device.
ALLOW_LEGACY_DEVICE_TOKEN=0
# Named credentials are bound to their device_id and cannot access other jobs.
# Startup imports these values into MySQL as hashes. After confirming the
# System Management credential list, remove the plaintext values from .env.
DEVICE_API_TOKENS_JSON='{"device_002":"generate-device-002-token","device_003":"generate-device-003-token"}'
# Keep 0 while existing devices migrate to POST /api/device/v1/patients.
# Set 1 after rollout so assessment uploads accept patient_id only and reject
# any patient that has not been registered in MySQL.
DEVICE_REQUIRE_REGISTERED_PATIENT=0

# ── Upload and temporary-session limits ─────────────────────────────────────
MAX_UPLOAD_FILE_BYTES=536870912
# Combined EEG + EMG/IMU limit for one direct browser assessment.
MAX_SESSION_UPLOAD_BYTES=2147483648
MAX_ZIP_BYTES=1073741824
MAX_ZIP_EXTRACTED_BYTES=4294967296
MAX_ZIP_MEMBERS=500
MAX_ZIP_COMPRESSION_RATIO=200
MIN_FREE_DISK_BYTES=2147483648
MAX_TRIALS=30
SESSION_TTL_HOURS=168
# Terminal/untracked device upload copies are removed after this recovery window.
# ACK still removes a completed job's raw upload immediately.
DEVICE_INPUT_TTL_HOURS=168
EXPORT_ROOT=/root/autodl-tmp/rehab_project/exports
# Optional TTF used for English, numbers and units in mixed Chinese PDF text.
# Ubuntu installs this path with the fonts-dejavu-core package.
PDF_LATIN_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
# Durable device uploads used to resume queued/running jobs after a restart.
DEVICE_JOB_ROOT=/root/autodl-tmp/rehab_project/device_jobs

# ── Report generation provider ──────────────────────────────────────────────
# Current cloud baseline uses local HF-format weights selected by the Model
# Settings page. GGUF is manual-only fallback; if needed, start
# start_gguf_fallback.sh and set LLM_PROVIDER=remote + LLM_REMOTE_URL=6008.
LLM_PROVIDER=local
LLM_REMOTE_URL=
LLM_REMOTE_TIMEOUT=300
LLM_MODEL_ID=qwen3_8b
LLM_MODEL_ROOT=/root/autodl-tmp/rehab_project/models
# Original HF-format models for fine-tuning/baseline testing.
LLM_ORIGINAL_MODEL_ROOT=/root/autodl-tmp/Qwen_data
# Cloud servers often have no outbound model-hub access. Keep local model
# loading offline once weights have been copied to LLM_ORIGINAL_MODEL_ROOT.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
# Optional: preselect one model from the System Management page candidate list.
# If unset, .env provider settings are used until an admin saves the page config.
LLM_ACTIVE_MODEL_ID=
# Optional: move runtime LLM selection outside the repository directory.
LLM_SETTINGS_PATH=

# Optional DeepSeek API mode.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=180
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0
DEEPSEEK_DISABLE_THINKING=1

# In-process transformers mode knobs. The default cloud deployment loads the
# selected HF-format report model inside the FastAPI process.
LLM_ADAPTER_DIR=../checkpoints_llm/yi15_6b
# On a 24 GB RTX 4090D, BF16 local loading is faster than 4-bit for Qwen3-8B.
LLM_LOAD_4BIT=0
LLM_USE_ADAPTER=0

# ── Report RAG integration ─────────────────────────────────────────────────
# off: no retrieval; shadow: retrieve and trace without changing the prompt;
# assist: prompt injection is still blocked unless RAG_ASSIST_APPROVED=1.
RAG_MODE=off
RAG_SERVICE_URL=http://127.0.0.1:8010
RAG_COLLECTION=rehab_knowledge_trial_v0_2
# Governed JSONL/manifest releases live outside replaceable Git releases.
KNOWLEDGE_RUNTIME_ROOT=/root/autodl-tmp/rehab_project/knowledge_base/runtime
RAG_TIMEOUT_SECONDS=20
RAG_REPORT_TOP_K=2
RAG_MAX_SOURCES=6
RAG_MAX_CONTEXT_CHARS=8000
RAG_ASSIST_APPROVED=0
# Shadow experiments may retrieve unreviewed Demo entries only when both this
# switch and the standalone service's RAG_ALLOW_DEMO are 1.
RAG_SHADOW_INCLUDE_DEMO=0
# Internal experiments only. Keep 0 until every indexed source is reviewed.
RAG_ALLOW_DEMO_IN_PROMPT=0
RAG_TRACE_ENABLED=1
RAG_TRACE_PATH=/root/autodl-tmp/rehab_project/rag_traces/report_retrieval.jsonl

# ── MySQL business store ────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=rehab_user
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_DB=rehab_mysql
